{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL",
      "description": "",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "title": "Last 5 Conversations",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT timestamp, question, answer, relevance, response_time, feedback FROM conversations c LEFT JOIN feedback f ON c.id = f.conversation_id ORDER BY timestamp DESC LIMIT 5",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "pieType": "pie"
      },
      "title": "+1 / -1 Feedback",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT CASE WHEN feedback > 0 THEN 'Thumbs Up' ELSE 'Thumbs Down' END as feedback_type, COUNT(*) as count FROM feedback GROUP BY feedback_type",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "NON_RELEVANT": { "color": "red", "index": 0, "text": "Non Relevant" }, "PARTLY_RELEVANT": { "color": "yellow", "index": 1, "text": "Partly Relevant" }, "RELEVANT": { "color": "green", "index": 2, "text": "Relevant" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green", "value": 0.7 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "id": 3,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Relevancy",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT SUM(CASE WHEN relevance = 'RELEVANT' THEN 1 ELSE 0 END)::float / COUNT(*)::float as relevance_rate FROM conversations",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Response Time (seconds)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT timestamp AS time, response_time FROM conversations ORDER BY timestamp",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Tokens Used",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT timestamp AS time, total_tokens FROM conversations ORDER BY timestamp",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "barRadius": 0,
        "barWidth": 0.97,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 200
      },
      "title": "Conversations by Relevance",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT relevance, COUNT(*) as count FROM conversations GROUP BY relevance ORDER BY count DESC",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 7,
      "options": {
        "barRadius": 0,
        "barWidth": 0.97,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "auto",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Model Used",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT model_used, COUNT(*) as count FROM conversations GROUP BY model_used ORDER BY count DESC",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["fitness", "rag", "ollama"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Fitness RAG Assistant",
  "uid": "fitness-assistant",
  "version": 1
}
